<Window x:Class="pr4cch1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pr4cch1"
        mc:Ignorable="d"
        Title="Практическая работа 4 - Завадский Таибова" Height="550" Width="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="10">
            <Button Content="Страница 1" Click="Page1_Click" Margin="5" Padding="10,5"/>
            <Button Content="Страница 2" Click="Page2_Click" Margin="5" Padding="10,5"/>
            <Button Content="Страница 3" Click="Page3_Click" Margin="5" Padding="10,5"/>
        </StackPanel>

        <Frame x:Name="mainFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>