<Page x:Class="pr4cch1.Page3"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Функция 3">

    <ScrollViewer>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="300"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Formula image -->
            <Image Source="function3.png" Grid.Row="0" Grid.ColumnSpan="2" 
                   Height="100" Margin="0,0,0,20" 
                   ToolTip="Формула функции 3" 
                   HorizontalAlignment="Center"/>

            <Label Content="x0 (начальное):" Grid.Row="1" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
            <TextBox x:Name="tbX0" Grid.Row="1" Grid.Column="1" Margin="5" Width="200" HorizontalAlignment="Left" 
                     ToolTip="Начальное значение x"/>

            <Label Content="xk (конечное):" Grid.Row="2" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
            <TextBox x:Name="tbXk" Grid.Row="2" Grid.Column="1" Margin="5" Width="200" HorizontalAlignment="Left" 
                     ToolTip="Конечное значение x"/>

            <Label Content="dx (шаг):" Grid.Row="3" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
            <TextBox x:Name="tbDx" Grid.Row="3" Grid.Column="1" Margin="5" Width="200" HorizontalAlignment="Left" 
                     ToolTip="Шаг dx"/>

            <Label Content="b:" Grid.Row="4" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
            <TextBox x:Name="tbB" Grid.Row="4" Grid.Column="1" Margin="5" Width="200" HorizontalAlignment="Left" 
                     ToolTip="Значение b"/>

            <Label Content="Результаты:" Grid.Row="5" Grid.Column="0" Margin="5" VerticalAlignment="Top" FontWeight="Bold"/>
            <TextBox x:Name="tbResults" Grid.Row="5" Grid.Column="1" Margin="5" Height="120" 
                     AcceptsReturn="True" IsReadOnly="True" Background="LightYellow" 
                     ToolTip="Список значений" VerticalScrollBarVisibility="Auto"/>

            <Label Content="График функции:" Grid.Row="6" Grid.ColumnSpan="2" Margin="5" FontWeight="Bold"/>

            <Border Grid.Row="7" Grid.ColumnSpan="2" Margin="5" Height="300" BorderBrush="Gray" BorderThickness="1" Background="White">
                <Canvas x:Name="chartCanvas" Background="White" ClipToBounds="True"/>
            </Border>

            <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="20">
                <Button Content="Вычислить" Click="Calculate_Click" Margin="5" Padding="20,5" Width="100"/>
                <Button Content="Очистить" Click="Clear_Click" Margin="5" Padding="20,5" Width="100"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>